# OPENAI_API_KEY=sk-your-key-here
# Hoặc dùng CURSOR_API_KEY nếu endpoint tương thích OpenAI
# CURSOR_API_KEY=your-cursor-key

# Tùy chọn: endpoint API (mặc định OpenAI)
# AI_API_BASE_URL=https://api.openai.com/v1

# Tùy chọn: model AI (mặc định gpt-4o-mini)
# AI_MODEL=gpt-4o-mini

# Cổng server API (mặc định 3001)
# PORT=3001
